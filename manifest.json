{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "0.2.0",
  "default_locale": "en",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_title": "Poe Notes",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://poe.com/*",
        "https://www.poe.com/*"
      ],
      "css": [
        "content/page.css"
      ],
      "js": [
        "vendor/turndown-7.2.4.js",
        "vendor/turndown-plugin-gfm-1.0.2.js",
        "vendor/jspdf-4.2.1.umd.min.js",
        "content/anchor.js",
        "content/export.js",
        "content/pdf.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
